# Токен бота: business.max.ru → Чат-боты → Интеграция → Получить токен

MAX_BOT_TOKEN=



# Текст кнопки входа в чат комментариев (у поста в канале; можно менять в /admin)

COMMENTS_CHAT_TEXT=Чат комментариев



# Текст кнопки перехода к пересланному сообщению в чате (можно менять в /admin)

COMMENTS_MESSAGE_BUTTON_TEXT=💬 Перейти к сообщению



# ID пользователей через запятую, которым разрешён доступ к /admin (корневые админы)

ADMIN_USER_IDS=



# Необязательно: стартовые значения рекламы (дальше правятся в /admin)

AD_TEXT=Реклама

AD_URL=https://max.ru



LOG_LEVEL=INFO


# Обязательно: публичный HTTPS URL, по которому MAX шлёт POST с Update (регистрируется в POST /subscriptions).
# Требования: https://, порт 443 снаружи (обычно nginx/Caddy проксирует на WEBHOOK_LISTEN).
# Пример: WEBHOOK_URL=https://bot.example.com/webhook
# Если путь не указан (только домен), используется /webhook

WEBHOOK_URL=

# Необязательно, 5–256 символов [a-zA-Z0-9_-]; проверяйте заголовок X-Max-Bot-Api-Secret

WEBHOOK_SECRET=

# Где слушает процесс внутри контейнера/сервера (прокси с 443 → сюда)

WEBHOOK_LISTEN=0.0.0.0:8000


# Опционально для docker compose build: прокси на хосте (tinyproxy/squid), чтобы pip шёл «как с сервера»
# Пример: HTTPS_PROXY=http://172.17.0.1:8888  и то же для HTTP_PROXY

HTTP_PROXY=

HTTPS_PROXY=

NO_PROXY=localhost,127.0.0.1

