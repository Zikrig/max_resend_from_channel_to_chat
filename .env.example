# Токен бота: business.max.ru → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=

# ID канала (в котором бот — администратор)
CHANNEL_CHAT_ID=

# ID чата для комментариев (где бот — администратор)
COMMENTS_CHAT_ID=

# Прямая ссылка на чат для комментариев (для кнопки в канале)
# Можно получить в настройках чата (Пригласить по ссылке)
COMMENTS_CHAT_LINK=

# Текст кнопки входа в чат комментариев
COMMENTS_CHAT_TEXT=Чат комментариев

# Текст второй кнопки у поста в канале — переход к пересланному сообщению в чате (можно менять в /admin)
COMMENTS_MESSAGE_BUTTON_TEXT= Сообщение

# ID пользователей через запятую, которым разрешен доступ к /admin
ADMIN_USER_IDS=

# Тихие часы в МСК. Примеры: 12:00-14:00 или 21:33-07:00
QUIET_HOURS=

# Включен ли мут чата по диапазону выше
CHAT_MUTE_ENABLED=false

LOG_LEVEL=INFO
