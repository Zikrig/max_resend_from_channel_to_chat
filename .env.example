# Токен бота: business.max.ru → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=

# ID канала (в котором бот — администратор)
CHANNEL_CHAT_ID=

# ID чата для комментариев (где бот — администратор)
COMMENTS_CHAT_ID=

# Прямая ссылка на чат для комментариев (для кнопки в канале)
# Можно получить в настройках чата (Пригласить по ссылке)
COMMENTS_CHAT_LINK=

# ID пользователей через запятую, которым разрешен доступ к /admin
ADMIN_USER_IDS=

LOG_LEVEL=INFO
