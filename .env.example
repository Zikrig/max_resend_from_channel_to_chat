# Токен бота: business.max.ru → Чат-боты → Интеграция → Получить токен
MAX_BOT_TOKEN=

# Чат, куда пересылать (ID группового чата; бота добавьте в этот чат)
TARGET_CHAT_ID=

# ID чата(ов), где идут комментарии к постам канала (через запятую).
# Бот должен быть администратором канала. ID можно взять из логов бота при первом сообщении
# или через API списка чатов, если доступно.
SOURCE_CHANNEL_CHAT_IDS=

# Если true — только сообщения с ответом/связью (link), иначе все сообщения из указанных чатов
COMMENTS_ONLY=false

LOG_LEVEL=INFO
